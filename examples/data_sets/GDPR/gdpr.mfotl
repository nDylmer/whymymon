(EXISTS data. EXISTS dataid. EXISTS dsid. use(data, dataid, dsid) AND NOT ((ONCE legal_grounds(dsid, data)) OR ((NOT ds_revoke(dsid, data)) SINCE ds_consent(dsid, data)))) OR
(EXISTS data. EXISTS dataid. EXISTS dsid. ds_deletion_request(data, dataid, dsid) AND EVENTUALLY[0,30] delete(data, dataid, dsid)) OR
(EXISTS data. EXISTS dataid. EXISTS dsid. collect(data, dataid, dsid) AND NOT (NEXT inform(dsid) OR ONCE inform(dsid))) OR
(EXISTS data. EXISTS dataid. EXISTS dsid. EXISTS processorid. (ds_deletion_request(data, dataid, dsid) AND ONCE share_with(processorid, dataid)) AND NOT (EVENTUALLY[0,30] notify_proc(processorid, dataid)))
